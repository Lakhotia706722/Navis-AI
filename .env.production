# Production Environment Configuration
# DO NOT commit secrets to git. Use CI/CD secrets management (GitHub Secrets, GitLab CI Variables, etc.)

# Database (use RDS in production)
DATABASE_URL=postgresql://maritime_user:CHANGE_ME@rds-endpoint:5432/maritime_studio

# Redis (use ElastiCache in production)
REDIS_URL=redis://CHANGE_ME:6379/0

# Object Storage (use AWS S3 in production)
MINIO_ENDPOINT=s3.amazonaws.com
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=maritime-studio-prod
MINIO_REGION=us-east-1

# API Configuration
ENVIRONMENT=production
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO

# FastAPI Settings
DEBUG=false
CORS_ORIGINS=https://your-frontend-domain.com

# JWT Configuration
JWT_SECRET_KEY=CHANGE_ME_WITH_STRONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# OpenAI Configuration
OPENAI_API_KEY=CHANGE_ME
OPENAI_ORG_ID=

# Blender Configuration
BLENDER_EXECUTABLE=/usr/bin/blender
BLENDER_RENDER_BACKEND=CPU
BLENDER_RENDER_ENGINE=CYCLES
BLENDER_SAMPLES=128
BLENDER_RESOLUTION_WIDTH=1920
BLENDER_RESOLUTION_HEIGHT=1080

# Notifications
WEBHOOK_URL=
SLACK_WEBHOOK_URL=
EMAIL_ENABLED=false

# Cost Control
DEFAULT_COST_THRESHOLD=100.0

# Monitoring & Logging
SENTRY_DSN=
LOG_LEVEL=INFO

# Security
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
